---
import { SITE } from '../site';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

// 현재 경로로 활성 메뉴 판별 (글은 개별 포스트/태그 페이지 포함)
const path = Astro.url.pathname;
const isActive = (base: string) =>
  base === '/posts/'
    ? path === '/' || path.startsWith('/posts') || path.startsWith('/tags')
    : path.startsWith(base);
const nav = [
  { href: '/posts/', ko: '글', en: 'writing' },
  { href: '/map/', ko: '사고 지도', en: 'map' },
  { href: '/book/', ko: '책', en: 'book' },
  { href: '/playground/', ko: '놀이터', en: 'play' },
  { href: '/about/', ko: '소개', en: 'about' },
  { href: '/rss.xml', ko: 'RSS', en: 'feed' },
];
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="DdFpk-SyU-dKRRvVVErO2uY9aFg-Op2RaNp-AHSWXPE" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#f0e4d2" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <slot name="head" />
  </head>
  <body>
    <div class="sky" aria-hidden="true"><i></i><span class="shoot s1"></span><span class="shoot s2"></span></div>
    <a
      class="apod-star"
      href="https://apod.nasa.gov/apod/astropix.html"
      target="_blank"
      rel="noopener noreferrer"
      title="오늘의 우주 · NASA APOD"
      aria-label="오늘의 우주 사진 보기 — NASA 천문 사진(APOD)"></a>
    <!-- 우측 여백의 초록별 — 누르면 「류기혁 행동 강령」 모달. APOD 별과 대칭. -->
    <button
      class="creed-star"
      type="button"
      title="류기혁 행동 강령"
      aria-label="류기혁 행동 강령 열기"
      aria-haspopup="dialog"></button>
    <dialog class="creed-dialog" aria-label="류기혁 행동 강령">
      <article class="creed-body">
        <p class="creed-kicker">🐿️ 이스터에그</p>
        <h2 class="creed-title">류기혁 행동 강령</h2>
        <p class="creed-sub">— 행동 강령 · v2 · 2026-07-24</p>
        <p class="creed-lead">
          요약을 견디는 건 다, 추상적 판단이 어떤 구체적 몸(관계·경험)을 입고 나온 것들이다.
        </p>
        <ol class="creed-list">
          <li>
            <strong>좌표.</strong> 바다는 <em>“판단”</em>이다 — 유일한 뿌리. 요약을 견디는 모든 것은
            판단이 육화된 것. 관계·실시간으로 드러나면 “그 사람이라서”, 형태·경험으로 드러나면
            “그 경험이라서”. 둘 다 판단. <b>나는 판단을 판다.</b>
          </li>
          <li>
            <strong>엔진.</strong> 요약은 결론을 뽑고 <em>판단을 버린다.</em> 그래서 판단과 분리되지
            않는 것만 살아남는다.
          </li>
          <li>
            <strong>판별식.</strong> 무엇을 하든 하나만 묻는다 — <b>“요약당하면 죽는가?”</b> Yes면
            손대지 않는다. (결론·정보 배달 = 판단이 제거된 것 = 바깥)
          </li>
          <li>
            <strong>도구.</strong> 도구는 판단의 <em>배달</em>을 넓히되, <em>판단하는 행위</em>를
            대체하지 않는다. 나는 루프 안에 남는다.
          </li>
          <li>
            <strong>원형.</strong> 씨앗은 이미 손에 있다. “판단을 파는 도구”의 프로토타입은 이미 돌고 있다.
          </li>
        </ol>
        <form method="dialog" class="creed-actions">
          <button class="creed-close" aria-label="닫기">닫기</button>
        </form>
      </article>
    </dialog>
    <script>
      const creedStar = document.querySelector('.creed-star');
      const creedDialog = document.querySelector('.creed-dialog');
      if (creedStar instanceof HTMLElement && creedDialog instanceof HTMLDialogElement) {
        creedStar.addEventListener('click', () => creedDialog.showModal());
        creedDialog.addEventListener('click', (e) => {
          if (e.target === creedDialog) creedDialog.close();
        });
      }
    </script>
    <header>
      <div class="topbar">
        <a href="/" class="brand">
          <span class="prompt">ryuk@blockchain:~$</span>
          <span class="site-name">{SITE.title}</span>
          <span class="cursor" aria-hidden="true"></span>
        </a>
        <nav class="menu">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={['menu-item', { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.ko}
                <span class="en">{item.en}</span>
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <div class="footzone">
      <footer aria-label="AI 크롤러 관측 로그">
        <div class="fcap">
          <span><span class="dot">●</span> AI CRAWLER LOG</span>
          <span>robots.txt: AI 전면 허용</span>
        </div>
        <div class="flog">
          <span class="ai">Observer/1.0</span> GET /book/skill.md
          <span class="ok">6h 주기 정기순찰</span><br />
          <span class="ai">Googlebot</span> · <span class="ai">ClaudeBot</span> ·
          <span class="ai">bingbot</span> · <span class="ai">GPTBot</span> ·
          <span class="ai">Applebot</span> GET /posts/*.md · /llms.txt · sitemap
          <span class="ok">최근 72h 검증 크롤러 312회 방문</span><br />
          <span class="ai">Googlebot</span> + <span class="ai">GoogleOther</span> 색인 재작업
          <span class="ok">최근 24h 84회 집중 방문</span>
        </div>
        <div class="froster">
          <b>다녀간 AI:</b> OpenAI · Anthropic · Google · Meta · Apple · xAI · Amazon · Microsoft ·
          Common Crawl
        </div>
        <div class="fmeta">
          © {new Date().getFullYear()} {SITE.author} ·
          <a href="/llms.txt">llms.txt</a> ·
          <a href="/rss.xml">RSS</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  /* Terminal theme — light default (paper terminal), dark via prefers-color-scheme (CRT).
     Variable contract (--bg/--fg/--muted/--accent/--border/--code-bg) kept so scoped
     component styles keep working; --amber/--faint/--panel/--scan are additions. */
  :root {
    --bg: #f4f5f1;
    --fg: #17191a;
    --muted: #5b6455;
    --faint: #8a9382;
    --accent: #1d7a44;
    --amber: #8a5a12;
    --border: #dadfd4;
    --code-bg: #e9ece4;
    --panel: #e9ece4;
    --scan: transparent;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0c0f0d;
      --fg: #e4e8e0;
      --muted: #8b9484;
      --faint: #545e4d;
      --accent: #7dff9b;
      --amber: #e7b45a;
      --border: #1e251b;
      --code-bg: #12160f;
      --panel: #12160f;
      --scan: rgba(255, 255, 255, 0.01);
    }
  }
  * {
    box-sizing: border-box;
  }
  /* reading body — original Pretendard sans for legibility */
  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      'Apple SD Gothic Neo',
      'Segoe UI',
      sans-serif;
    line-height: 1.75;
    font-size: 1.0625rem;
    -webkit-font-smoothing: antialiased;
    background-image: repeating-linear-gradient(
      0deg,
      transparent 0 3px,
      var(--scan) 3px 4px
    );
  }
  /* terminal-flavored UI chrome uses mono */
  .topbar,
  .menu,
  .footzone,
  .listhead,
  .tagline,
  code,
  pre,
  .meta,
  .post-list time {
    font-family:
      ui-monospace,
      SFMono-Regular,
      'SF Mono',
      Menlo,
      Consolas,
      monospace;
  }
  header,
  main,
  footer {
    max-width: 40rem;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  /* header topbar */
  header {
    padding-top: 1.6rem;
  }
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    text-decoration: none;
  }
  .prompt {
    color: var(--faint);
    font-size: 0.9rem;
  }
  .site-name {
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: 0.02em;
    color: var(--accent);
  }
  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    background: var(--accent);
    translate: 0 0.12em;
    animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .menu {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .menu a {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    border: 1px solid var(--border);
    background: var(--panel);
    border-radius: 5px;
    padding: 0.28rem 0.6rem;
    color: var(--fg);
    font-size: 0.86rem;
    text-decoration: none;
    transition:
      border-color 0.12s,
      color 0.12s;
  }
  .menu a .en {
    color: var(--faint);
    font-size: 0.68rem;
  }
  .menu a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .menu a:hover .en {
    color: var(--accent);
  }
  .menu a.active {
    border-color: var(--accent);
    background: var(--accent);
    color: var(--bg);
  }
  .menu a.active .en {
    color: var(--bg);
    opacity: 0.7;
  }
  main {
    padding-top: 1.6rem;
    padding-bottom: 3rem;
    min-height: 60vh;
  }
  /* footer crawler-log region */
  .footzone {
    border-top: 1px solid var(--border);
    background: var(--panel);
    margin-top: 2.5rem;
  }
  footer {
    padding-top: 1.5rem;
    padding-bottom: 2.6rem;
    color: var(--muted);
    font-size: 0.875rem;
  }
  .fcap {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.7rem;
    color: var(--faint);
    letter-spacing: 0.06em;
    padding-bottom: 0.7rem;
    margin-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }
  .fcap .dot {
    color: var(--accent);
  }
  .flog {
    font-size: 0.72rem;
    color: var(--muted);
    line-height: 1.95;
  }
  .flog .ai {
    color: var(--amber);
  }
  .flog .ok {
    color: var(--accent);
  }
  .froster {
    margin-top: 0.7rem;
    color: var(--faint);
    font-size: 0.72rem;
    line-height: 1.7;
  }
  .froster b {
    color: var(--muted);
    font-weight: 400;
  }
  .fmeta {
    margin-top: 1.1rem;
    padding-top: 0.85rem;
    border-top: 1px dashed var(--border);
    color: var(--faint);
    font-size: 0.78rem;
  }
  .fmeta a,
  .froster a {
    color: var(--faint);
  }
  a {
    color: var(--accent);
  }
  /* post list — titles in --fg (calm), accent on hover */
  .post-list a {
    color: var(--fg);
  }
  .post-list a:hover {
    color: var(--accent);
  }
  h1,
  h2,
  h3 {
    line-height: 1.35;
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.01em;
  }
  h1 {
    font-size: 1.7rem;
    margin-top: 0.5rem;
  }
  h2 {
    font-size: 1.3rem;
  }
  h3 {
    font-size: 1.1rem;
  }
  code {
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.85em;
  }
  pre {
    background: var(--code-bg);
    border: 1px solid var(--border);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    line-height: 1.55;
  }
  pre code {
    background: none;
    border: none;
    padding: 0;
  }
  blockquote {
    margin: 1rem 0;
    padding: 0.25rem 1rem;
    border-left: 2px solid var(--amber);
    color: var(--muted);
  }
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  th,
  td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  th {
    color: var(--amber);
    font-weight: 600;
  }
  img {
    max-width: 100%;
    height: auto;
  }
  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  /* 밤하늘 — 다크 모드 전용 별밭 (좌표 시드 20260721로 고정: 항상 같은 하늘).
     본문 컬럼(24~76vw)은 밀도·밝기를 낮춰 가독성 보호. */
