---
import { SITE } from '../site';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#f0e4d2" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <slot name="head" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-name">{SITE.title}</a>
        <div class="menu">
          <a href="/posts/">글</a>
          <a href="/book/">책</a>
          <a href="/about/">소개</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        © {new Date().getFullYear()} {SITE.author} ·
        <a href="/llms.txt">llms.txt</a> ·
        <a href="/rss.xml">RSS</a>
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --fg: #1a1a1a;
    --muted: #6b6b6b;
    --accent: #0b57d0;
    --border: #e5e5e5;
    --code-bg: #f5f5f5;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #16181c;
      --fg: #e8e8e8;
      --muted: #9a9a9a;
      --accent: #8ab4f8;
      --border: #33363c;
      --code-bg: #23262c;
    }
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family:
      Pretendard,
      -apple-system,
      BlinkMacSystemFont,
      'Apple SD Gothic Neo',
      'Segoe UI',
      sans-serif;
    line-height: 1.75;
    font-size: 1.0625rem;
    -webkit-font-smoothing: antialiased;
  }
  header,
  main,
  footer {
    max-width: 42rem;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  header {
    padding-top: 2rem;
    padding-bottom: 1rem;
  }
  nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .site-name {
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--fg);
  }
  .menu {
    display: flex;
    gap: 1rem;
  }
  .menu a {
    color: var(--muted);
    text-decoration: none;
  }
  .menu a:hover {
    color: var(--fg);
  }
  main {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
    min-height: 60vh;
  }
  footer {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    padding-bottom: 2.5rem;
    color: var(--muted);
    font-size: 0.875rem;
  }
  footer a {
    color: var(--muted);
  }
  a {
    color: var(--accent);
  }
  h1,
  h2,
  h3 {
    line-height: 1.35;
    margin: 2rem 0 0.75rem;
  }
  h1 {
    font-size: 1.75rem;
    margin-top: 0.5rem;
  }
  h2 {
    font-size: 1.35rem;
  }
  h3 {
    font-size: 1.125rem;
  }
  code {
    background: var(--code-bg);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    font-size: 0.875em;
  }
  pre {
    background: var(--code-bg);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    line-height: 1.55;
  }
  pre code {
    background: none;
    padding: 0;
  }
  blockquote {
    margin: 1rem 0;
    padding: 0.25rem 1rem;
    border-left: 3px solid var(--border);
    color: var(--muted);
  }
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9375rem;
  }
  th,
  td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  img {
    max-width: 100%;
    height: auto;
  }
  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
</style>
