---
import Base from '../layouts/Base.astro';
import PostList from '../components/PostList.astro';
import { SITE } from '../site';
import { getPublishedPosts } from '../lib/posts';

const posts = (await getPublishedPosts()).slice(0, 10);
---

<Base>
  <p class="mission">
    AI가 콘텐츠를 쏟아내는 시대에, <span class="hl">사람이 직접 겪고 쓴 기록.</span>
  </p>
  <p class="tagline">// {SITE.tagline} — 개발자 류기혁의 개인 블로그</p>
  <h2 class="listhead"><span class="c">▸</span> 최근 글</h2>
  <PostList posts={posts} />
  <p class="allposts"><a href="/posts/">전체 글 보기 →</a></p>
</Base>

<style>
  .mission {
    font-size: 1.05rem;
    margin: 1rem 0 0.35rem;
    max-width: 36rem;
    line-height: 1.65;
  }
  .mission .hl {
    color: var(--amber);
  }
  .tagline {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0;
  }
  .listhead {
    font-size: 1.05rem;
    color: var(--accent);
    letter-spacing: 0.02em;
    margin: 2.4rem 0 1.2rem;
  }
  .listhead .c {
    color: var(--faint);
  }
  .allposts {
    margin-top: 2rem;
    font-size: 0.9rem;
  }
</style>
